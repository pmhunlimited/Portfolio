{
  "entities": {
    "Project": {
      "title": "Project",
      "description": "A portfolio project with AI-generated metadata.",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "Project title" },
        "slug": { "type": "string", "description": "URL-friendly slug" },
        "content": { "type": "string", "description": "AI-written Power Pitch" },
        "techStack": { 
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "icon": { "type": "string" }
            }
          }
        },
        "url": { "type": "string", "description": "Project URL" },
        "thumbnailUrl": { "type": "string", "description": "Thumbnail image URL" },
        "galleryImages": { "type": "array", "items": { "type": "string" }, "description": "Up to 5 images for the project" },
        "demoLogin": {
          "type": "object",
          "properties": {
            "username": { "type": "string" },
            "password": { "type": "string" },
            "note": { "type": "string" }
          }
        },
        "type": { "type": "string", "enum": ["web", "app"] },
        "waMessage": { "type": "string", "description": "Tailored WhatsApp message" },
        "seoData": {
          "type": "object",
          "properties": {
            "metaTitle": { "type": "string" },
            "metaDescription": { "type": "string" },
            "keywords": { "type": "array", "items": { "type": "string" } }
          }
        },
        "performance": {
          "type": "object",
          "properties": {
            "speed": { "type": "number" },
            "security": { "type": "number" }
          }
        },
        "inquiriesCount": { "type": "integer" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "slug", "url", "type"]
    },
    "Settings": {
      "title": "Global Settings",
      "description": "Global application configuration.",
      "type": "object",
      "properties": {
        "appTitle": { "type": "string" },
        "heroSubtext": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    },
    "Keys": {
      "title": "API Keys Vault",
      "description": "Secure storage for system API keys and admin settings.",
      "type": "object",
      "properties": {
        "gemini": { "type": "string" },
        "deepseek": { "type": "string" },
        "pagespeed": { "type": "string" },
        "adminPassword": { "type": "string" },
        "adminUsername": { "type": "string" },
        "authorizedEmail": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "firestore": {
    "/settings/global": {
      "schema": "Settings",
      "description": "Global settings for app title and branding"
    },
    "/settings/keys": {
      "schema": "Keys",
      "description": "Secure API keys and admin identity"
    },
    "/projects/{projectId}": {
      "schema": "Project",
      "description": "Store of all portfolio projects"
    }
  }
}
